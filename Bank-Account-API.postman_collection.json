{
  "info": {
    "name": "Bank Account Management API",
    "description": "API collection for the Bank Account Management System with Axon Framework and Event Sourcing.\n\nBase URL: http://localhost:8080",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Create Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('accountId', jsonData.accountId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerName\": \"John Doe\",\n  \"initialBalance\": 1000.50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts"]
            }
          }
        },
        {
          "name": "Get Account",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}"]
            }
          }
        },
        {
          "name": "Deposit Money",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500.75\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}/deposit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}", "deposit"]
            }
          }
        },
        {
          "name": "Withdraw Money",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 200.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}/withdraw",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}", "withdraw"]
            }
          }
        },
        {
          "name": "Close Account",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}/close",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}", "close"]
            }
          }
        }
      ]
    },
    {
      "name": "Queries",
      "item": [
        {
          "name": "Get Event Stream",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}", "events"]
            }
          }
        },
        {
          "name": "Get Balance at Timestamp",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}/balance-at/{{timestamp}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}", "balance-at", "{{timestamp}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Replay Projection",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/admin/replay/{{processingGroup}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "replay", "{{processingGroup}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accountId",
      "value": ""
    },
    {
      "key": "timestamp",
      "value": "2026-06-13T16:00:00Z"
    },
    {
      "key": "processingGroup",
      "value": "current_account_view"
    }
  ]
}
